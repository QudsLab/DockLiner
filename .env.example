# DockLiner Environment Config
# Copy to .env and fill in your values

DOCKLINER_DB_PATH=./dockliner.db
DOCKLINER_PROJECTS_DIR=./projects
DOCKLINER_GITHUB_CACHE=./github-cache
DOCKLINER_LOGS_DIR=./logs
DOCKLINER_SECRET_KEY=change-me-in-production-1234567890
DOCKLINER_ADMIN_USER=admin
DOCKLINER_ADMIN_PASS=admin
DOCKLINER_HOST=0.0.0.0
DOCKLINER_PORT=8080
